{
  "name": "fk-web",
  "version": "1.0.0",
  "description": "Website for Guild of Physics",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "typegen": "next typegen",
    "typecheck": "tsgo --noEmit",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "generate:migration": "payload migrate:create --skip-empty",
    "generate:payload": "pnpm generate:importmap && pnpm generate:types && pnpm generate:migration",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint .",
    "migrate": "payload migrate",
    "payload": "payload",
    "start": "next start",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@date-fns/tz": "^1.4.1",
    "@payloadcms/admin-bar": "^3.84.1",
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/email-nodemailer": "^3.84.1",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-form-builder": "^3.84.1",
    "@payloadcms/plugin-import-export": "^3.84.1",
    "@payloadcms/plugin-redirects": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "^3.84.1",
    "@plaiceholder/next": "^3.0.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "compress-pdf": "^0.6.2",
    "date-fns": "^4.1.0",
    "graphql": "^16.14.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.2",
    "nextjs-toploader": "^3.9.17",
    "payload": "^3.84.1",
    "payload-oauth2": "^1.0.20",
    "plaiceholder": "^3.0.0",
    "react": "^19.2.6",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^19.2.6",
    "react-email": "^6.1.1",
    "react-social-icons": "^6.26.0",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "postcss": "^8.5.14",
    "simple-git-hooks": "^2.13.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "^11"
  },
  "packageManager": "pnpm@11.0.3"
}
